APP_NAME=Bnaia
APP_ENV=local
APP_KEY=base64:lh/zY1uJJzCcvR0kgCV+67aC9YIHGwb3SIO4eAZrnyE=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
# APP_URL=http://192.168.1.40:8000
# APP_URL=https://e0dd1667bfad.ngrok-free.app
FRONT_END_URL=http://127.0.0.1:3000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=eramo
DB_USERNAME=root
DB_PASSWORD=

# Database Read/Write Splitting (Optional - for production with read replicas)
# Leave empty to use DB_HOST for all operations (development mode)
# DB_WRITE_HOST=primary-db.example.com
# DB_READ_HOST_1=replica-1.example.com
# DB_READ_HOST_2=replica-2.example.com
# DB_READ_HOST_3=replica-3.example.com

BROADCAST_DRIVER=log

FILESYSTEM_DISK=public
SESSION_DRIVER=database
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1


# Start QUEUE Engine
QUEUE_CONNECTION=database
# End QUEUE Engine

# Start Cache Engine
# CACHE_DRIVER=database
CACHE_DRIVER=redis
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# End Cache Engine



# Start Search Engine
SCOUT_DRIVER=meilisearch
SCOUT_QUEUE=false
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=
# End Search Engine

# Start Email SMTP Service
