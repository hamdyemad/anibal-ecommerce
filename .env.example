APP_NAME=Anibal
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONT_END_URL=http://localhost:5173

# Performance Profiling (set to true to enable performance headers)
PERFORMANCE_PROFILING=true

LOG_DEPRECATIONS_CHANNEL=null

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password

BROADCAST_DRIVER=log

FILESYSTEM_DISK=public
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

# Disable Telescope for performance
TELESCOPE_ENABLED=false

# Start QUEUE Engine
QUEUE_CONNECTION=sync
# End QUEUE Engine

# Start Cache Engine
CACHE_DRIVER=file
# CACHE_DRIVER=database  # Too slow - uses database queries
# CACHE_DRIVER=redis     # Best performance but requires Redis installation
# REDIS_CLIENT=predis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379
# End Cache Engine



# Start Search Engine
SCOUT_DRIVER=meilisearch
SCOUT_QUEUE=false
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=your_meilisearch_master_key
# End Search Engine

LOG_CHANNEL=stack
LOG_LEVEL=debug



# Start Email SMTP Service
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=your_mail_username
MAIL_PASSWORD=your_mail_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"
# End Email SMTP Service

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Disable Vite dev server - use built assets

# VITE_DEV_SERVER_URL=


# WhatsApp API Configuration
WHATSAPP_API_URL=https://your-whatsapp-provider.com/api/send
WHATSAPP_API_TOKEN=your_api_token_here

# Google Api Integration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback


